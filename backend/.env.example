# Airtable setup for auth + invites
#
# 1) Create table "Users" with fields:
#    - Email (Email) — unique login identity
#    - Name (Single line text)
#    - Password Hash (Single line text) — stores bcrypt hashes only
#    - Created time is automatic via record createdTime
#
# 2) Team members table must have:
#    - Email (Email) — used to match invited users
#    - Name, Role, etc. (existing)
#    - Deleted (Checkbox) — soft delete; unchecked = active invite
#
# 3) Set in this file:
#    AUTH_SECRET=long-random-string
#    ADMIN_EMAILS=you@company.com
#
AIRTABLE_PAT=
AIRTABLE_BASE_ID=
PORT=4000
FRONTEND_ORIGIN=http://localhost:3000
AUTH_SECRET=change-me-to-a-long-random-secret
ADMIN_EMAILS=
